  payload    Json
  createdAt  DateTime           @default(now())

  @@unique([orgId, dedupKey])
  @@index([orgId, createdAt])
}

model VendorFiatPayoutProfile {
  id                    String          @id @default(cuid())
  vendorId              String          @unique
  provider              String          @default("CIRCLE")
  currency              String          @default("USD")
  circleBeneficiaryId   String?
  circleBankAccountId   String?
  providerRecipientRef  Json?
  payoutMethodType      PayoutMethodType @default(BANK_WIRE)
  payoutDetailsJson     Json
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([vendorId])
}

// ----- Day 43: Treasury Policy Engine + Risk Controls -----

model TreasuryPolicy {
  id        String       @id @default(cuid())
  orgId     String
  version   Int
  isActive  Boolean      @default(true)
  rules     Json
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, version])
  @@index([orgId, isActive])
}

enum TreasuryApprovalStatus {
  REQUESTED
  APPROVED
  REJECTED
}

model TreasuryPayoutApproval {
  id                String                  @id @default(cuid())
  orgId             String
  intentId          String                  @unique
  status            TreasuryApprovalStatus  @default(REQUESTED)
  requestedByUserId String?
  approvedByUserId  String?
  rejectedByUserId  String?
  reason            String?
  createdAt         DateTime                @default(now())
  decidedAt         DateTime?
  org               Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  intent            TreasuryPayoutIntent    @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([orgId, status, createdAt])
}

enum TreasuryRiskStatus {
  CLEAR
  REQUIRES_APPROVAL
  BLOCKED
}

// ----- Day 45: Treasury Balance Snapshots + Reconciliation -----

model TreasuryBalanceSnapshot {
  id           String                @id @default(cuid())
  orgId        String
  account      TreasuryLedgerAccount
  currency     String
  balanceMinor BigInt
  asOf         DateTime
  createdAt    DateTime              @default(now())

  @@unique([orgId, account, currency, asOf])
  @@index([orgId, asOf])
}

enum ReconciliationSeverity {
  INFO
  WARN
  CRITICAL
}

model TreasuryReconciliationCheck {
  id          String                  @id @default(cuid())
  orgId       String
  asOf        DateTime
  results     Json
  maxSeverity ReconciliationSeverity  @default(INFO)
  createdAt   DateTime                @default(now())

  @@index([orgId, asOf])
  @@index([orgId, maxSeverity, createdAt])
}

// ----- Day 46: Multi-Wallet + Mint Registry + Spend Policy -----

enum TreasuryWalletType {
  HOT
  WARM
  OPERATIONAL
}

model TreasuryWallet {
  id        String             @id @default(cuid())
  orgId     String
  name      String
  type      TreasuryWalletType
  chain     TreasuryChain      @default(SOLANA)
  address   String
  isActive  Boolean            @default(true)
  metadata  Json?
  createdAt DateTime           @default(now())
  org       Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, address])
  @@index([orgId, type, isActive])
}

model TreasuryMintRegistry {
  id          String        @id @default(cuid())
  chain       TreasuryChain @default(SOLANA)
  symbol      String
  mintAddress String
  decimals    Int
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  @@unique([chain, mintAddress])
  @@index([chain, symbol])
}

model TreasurySpendPolicy {
  id                     String       @id @default(cuid())
  orgId                  String       @unique
  maxHotTransferMinor    BigInt       @default(500000)
  requireApprovalOverMinor BigInt     @default(1000000)
  dailyHotCapMinor       BigInt       @default(5000000)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  org                    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// ----- Day 47: Treasury Safety Controls (Kill Switches) -----

model TreasurySafetyControls {
  id              String       @id @default(cuid())
  orgId           String?
  payoutsPaused   Boolean      @default(false)
  onchainPaused   Boolean      @default(false)
  providerPaused  Json         @default("{}")
  railsPaused     Json         @default("{}")
  reason          String       @default("")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  org             Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId])
  @@index([orgId])
}
